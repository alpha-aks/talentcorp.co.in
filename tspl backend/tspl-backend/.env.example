# Comma-separated list of allowed frontend origins for CORS
# Example: https://www.tspl.com,https://careers.tspl.com
# Single-origin shorthand is also supported.
FRONTEND_URL=https://tspl.brandboosters.host
FRONTEND_URLS=http://localhost:3000,https://tspl.brandboosters.host

# WabaSMSBox configuration
WABA_API_KEY=replace_with_real_key
WABA_BOT_ID=TSPL_BOT_01
WABASMSBOX_API_KEY=replace_with_real_key
WABASMSBOX_BOT_ID=TSPL_BOT_01
WABASMSBOX_RCS_ENDPOINT=https://wabasmsbox.com/REST/direct/sendRCS
WABA_BASE_URL=https://wabasmsbox.com
WABA_SMS_SEND_ENDPOINT=https://wabasmsbox.com/api/json/sendsms/
WABA_FILE_UPLOAD_ENDPOINT=https://wabasmsbox.com/api/uploadFile
WABA_BULK_PUSH_ENDPOINT=https://wabasmsbox.com/api/bulk-push
WABA_SMS_TEMPLATES_ENDPOINT=https://wabasmsbox.com/api/getSmsTemplates
WABA_RCS_SEND_ENDPOINT=https://wabasmsbox.com/REST/direct/sendRCS
WABA_RCS_TEMPLATE_ENDPOINT=https://wabasmsbox.com/REST/direct/getRcsTemplateJson
WABA_AGENT_ID=

# Contact auto-responder template
CONTACT_TEMPLATE_CODE=tspl_contact_thanks
